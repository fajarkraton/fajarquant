#!/usr/bin/env bash
# fajarquant pre-commit hook (v4 — adds Phase F F.13 dispatch-decision gate).
#
# Source of truth for `.git/hooks/pre-commit`. Install via:
#   ./scripts/git-hooks/install-hooks.sh
#
# Layers (run in order; abort on first failure):
#   1. cargo fmt --check                                      (Rust style)
#   2. cargo clippy --lib -- -D warnings                      (Rust lint)
#   3. scripts/audit_unwrap.py --summary                      (no production .unwrap())
#   4. make verify-bilingual-corpus                           (Phase E1.6 gate, conditional)
#   5. make verify-f13-decision                               (Phase F.13.5 gate, conditional)
#
# Layers 4-5 only fire when staged changes touch their trigger paths.
# This keeps the hook fast for unrelated commits (~<0.1 s no-op).

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# Layer 1: cargo fmt --check
if ! cargo fmt -- --check 2>&1; then
    echo ""
    echo "❌ fmt drift detected. Run 'cargo fmt' and re-stage."
    exit 1
fi

# Layer 2: cargo clippy --lib -- -D warnings
if ! cargo clippy --lib -- -D warnings 2>&1; then
    echo ""
    echo "❌ clippy warnings. Fix before committing."
    exit 1
fi

# Layer 3: production .unwrap() audit via 3-layer filter
if [ -x scripts/audit_unwrap.py ]; then
    UNWRAP_SUMMARY=$(python3 scripts/audit_unwrap.py --summary 2>&1)
    UNWRAP_COUNT=$(echo "$UNWRAP_SUMMARY" | grep "Total production" | awk '{print $5}')
    if [ -n "$UNWRAP_COUNT" ] && [ "$UNWRAP_COUNT" -gt 0 ]; then
        echo "❌ $UNWRAP_COUNT production .unwrap() detected. Use .expect(\"reason\") or ?"
        echo "   See V26 Plan Hygiene Rule 3 (prevention layer)."
        echo "$UNWRAP_SUMMARY"
        exit 1
    fi
fi

# Layer 4: Phase E E1.6 bilingual-corpus gate (conditional on staged changes).
# Trigger paths (any one staged ⇒ run gate):
#   - data/phase_e/corpus_id_dedup_exact/*/_manifest.json
#   - python/phase_e/intllm_en.py
#   - python/phase_e/scripts/verify_bilingual_corpus.py
#   - docs/FJQ_PHASE_E_BILINGUAL_CORPUS_V1.md
STAGED=$(git diff --cached --name-only)
TRIGGER=0
while IFS= read -r f; do
    case "$f" in
        data/phase_e/corpus_id_dedup_exact/*/_manifest.json) TRIGGER=1 ;;
        python/phase_e/intllm_en.py) TRIGGER=1 ;;
        python/phase_e/scripts/verify_bilingual_corpus.py) TRIGGER=1 ;;
        docs/FJQ_PHASE_E_BILINGUAL_CORPUS_V1.md) TRIGGER=1 ;;
    esac
done <<< "$STAGED"

if [ "$TRIGGER" -eq 1 ]; then
    if ! make verify-bilingual-corpus 2>&1; then
        echo ""
        echo "❌ verify-bilingual-corpus FAIL. Spec doc / manifests / shim drift."
        echo "   See docs/FJQ_PHASE_E_BILINGUAL_CORPUS_V1.md §5 for invariants."
        exit 1
    fi
fi

# Layer 5: Phase F F.13 dispatch-decision gate (conditional on staged changes).
# Trigger paths (any one staged ⇒ run gate):
#   - tests/fixtures/f13_dispatch_anchors.toml
#   - docs/FJQ_PHASE_F_F13_*.md  (any of FINDINGS, PRODUCTION_PLAN, DISPATCH_DECISION)
#   - scripts/verify_f13_dispatch.py
F13_TRIGGER=0
while IFS= read -r f; do
    case "$f" in
        tests/fixtures/f13_dispatch_anchors.toml) F13_TRIGGER=1 ;;
        docs/FJQ_PHASE_F_F13_*.md) F13_TRIGGER=1 ;;
        scripts/verify_f13_dispatch.py) F13_TRIGGER=1 ;;
    esac
done <<< "$STAGED"

if [ "$F13_TRIGGER" -eq 1 ]; then
    if ! make verify-f13-decision 2>&1; then
        echo ""
        echo "❌ verify-f13-decision FAIL. Anchors / decision-doc / invariants drift."
        echo "   See docs/FJQ_PHASE_F_F13_DISPATCH_DECISION.md §5 for verdict gates."
        exit 1
    fi
fi

# ── Final summary ──
SUMMARY="✅ pre-commit OK (fmt, clippy, 0 production unwraps"
if [ "$TRIGGER" -eq 1 ]; then SUMMARY="$SUMMARY, bilingual-corpus 8/8"; fi
if [ "$F13_TRIGGER" -eq 1 ]; then SUMMARY="$SUMMARY, f13-dispatch 21/21"; fi
SUMMARY="$SUMMARY)"
echo "$SUMMARY"
